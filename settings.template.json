{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node scripts/claude-harness/hook-guard-destructive.mjs", "timeout": 10 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node scripts/claude-harness/hook-guard-secrets.mjs", "timeout": 10 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node scripts/claude-harness/hook-syntax-check.mjs", "timeout": 15 },
          { "type": "command", "command": "node scripts/claude-harness/hook-verify-due.mjs", "timeout": 10 }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "node scripts/claude-harness/hook-governing-principles.mjs", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "node scripts/claude-harness/hook-open-tasks.mjs", "timeout": 10 }
        ]
      }
    ]
  }
}
